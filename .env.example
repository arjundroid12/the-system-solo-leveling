# Solo Leveling System — Environment Variables

# Turso database (required for cloud sync)
SYSTEM_DB_URL=libsql://your-db.turso.io
SYSTEM_LIBSQL_TOKEN=your-turso-token

# Z.AI API key (required for AI quest generation)
ZAI_API_KEY=your-zai-api-key

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-public-key
VAPID_PUBLIC_KEY=your-public-key
VAPID_PRIVATE_KEY=your-private-key
VAPID_SUBJECT=mailto:your@email.com

# Cron secret (for daily reminder endpoint protection)
CRON_SECRET=your-cron-secret
